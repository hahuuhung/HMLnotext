# Backend Environment Variables
NODE_ENV=production
PORT=3000

# Database (Prisma SQLite by default, change if using Postgres)
DATABASE_URL=file:./dev.db

# Redis for BullMQ Queue
REDIS_HOST=redis
REDIS_PORT=6379

# Security
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRATION=7d
ENCRYPTION_KEY=32-character-long-secret-key-for-aes-256

# Monitoring (Optional)
SENTRY_DSN=
